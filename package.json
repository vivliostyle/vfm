{
  "name": "@vivliostyle/vfm-root",
  "private": true,
  "description": "Custom Markdown syntax specialized in book authoring.",
  "engines": {
    "node": ">= 20"
  },
  "volta": {
    "node": "20.19.5"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm --workspaces run build --if-present",
    "test": "npm --workspaces run test --if-present",
    "format": "npm --workspaces run format --if-present",
    "lint": "npm --workspaces run lint --if-present"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.19.39",
    "eslint": "^10.2.0",
    "eslint-config-flat-gitignore": "^2.3.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "shx": "^0.4.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  },
  "type": "module"
}
