{
  "name": "@vivliostyle/remark-ruby",
  "version": "1.0.0",
  "description": "remark plugin to support `{...|...}` ruby annotation syntax used by VFM.",
  "license": "Apache-2.0",
  "engines": {
    "node": ">= 22"
  },
  "type": "module",
  "main": "lib/ruby.js",
  "types": "lib/ruby.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vivliostyle/vfm.git",
    "directory": "packages/remark-ruby"
  },
  "files": [
    "lib"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "shx rm -rf lib && tsc",
    "test": "tsc --project tests/tsconfig.json && vitest run",
    "format": "prettier --write --ignore-path ../../.gitignore --ignore-path ../../.prettierignore .",
    "lint": "eslint --fix ."
  },
  "dependencies": {
    "@types/mdast": "^3.0.0",
    "@types/unist": "^2.0.0",
    "mdast-util-to-hast": "^11.3.0",
    "unified": "^9.2.0",
    "unist-builder": "^3.0.1"
  },
  "devDependencies": {
    "rehype-stringify": "^8.0.0",
    "remark-breaks": "^1.0.5",
    "remark-parse": "^8.0.3",
    "remark-rehype": "^8.1.0"
  }
}
