{
  "name": "@vivliostyle/remark-sectionize",
  "version": "1.0.1",
  "description": "remark plugin to wrap headings in `<section class=\"levelN\">` elements, with VFM-specific extensions for non-section markers and section-end marks. Derived from `remark-sectionize` (Jake Low, 2019).",
  "license": "MIT",
  "engines": {
    "node": ">= 22"
  },
  "type": "module",
  "main": "lib/section.js",
  "types": "lib/section.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vivliostyle/vfm.git",
    "directory": "packages/remark-sectionize"
  },
  "files": [
    "lib"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "shx rm -rf lib && tsc",
    "test": "tsc --project tests/tsconfig.json && vitest run",
    "format": "prettier --write --ignore-path ../../.gitignore --ignore-path ../../.prettierignore .",
    "lint": "eslint --fix ."
  },
  "dependencies": {
    "@types/hast": "^2.0.0",
    "@types/mdast": "^3.0.0",
    "@types/unist": "^2.0.0",
    "unist-util-find-after": "^4.0.1",
    "unist-util-visit-parents": "^5.1.3",
    "vfile": "^4.2.1"
  },
  "devDependencies": {
    "rehype-format": "^3.1.0",
    "rehype-raw": "^5.1.0",
    "rehype-stringify": "^8.0.0",
    "remark-attr": "^0.11.1",
    "remark-parse": "^8.0.2",
    "remark-rehype": "^8.1.0",
    "unified": "^9.2.0"
  }
}
